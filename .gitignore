# =====================================================================
# .gitignore --- gridpilot reproducibility kit (github.com/denisa-c/gridpilot)
# =====================================================================

# -- Python ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
*.egg-info/
*.eggs/
build/
dist/
pip-log.txt
pip-delete-this-directory.txt

# -- Test / lint caches --------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# -- Jupyter --------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_meta.json

# -- OS / Editor ----------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# -- Local secrets / API tokens ------------------------------------
.entsoe_api_key
secrets.yaml
.env.local
.env.*.local

# -- Large generated data (regenerated by run_all_experiments.sh) ---
# Source-of-truth raw data is fetched/created by the run scripts; the
# CSV/Parquet outputs below are reproducible
*.csv.gz
*.parquet.tmp



# -- LaTeX build artefacts -----------------------------------------
# Papers live under ../papers/ at the project root, but if anyone
# clones the kit into a setup where papers are siblings, mask their
# auxiliary files here too.
**/*.aux
**/*.bbl
**/*.blg
**/*.fdb_latexmk
**/*.fls
**/*.log
**/*.out
**/*.synctex.gz
**/*.toc
**/_minted-*/
**/auto/
papers/build/

# -- Reinforcement-learning / RAPS submodule outputs ---------------
raps/simulation_results/
raps/raps-output-*
raps/ppo_raps_logs/
raps/models/fmu-models/
raps/models/POWER9CSM/
raps/.shell-completion-cache

# -- Shell completion / misc ---------------------------------------
*.prof
*.npz
*.bak
*.orig

# -- Keep dependency manifests versioned ----------------------------
!requirements.txt
!raps/api_client/requirements.txt
!raps/pyproject.toml
