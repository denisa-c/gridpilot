# =====================================================================
# .gitignore --- gridpilot reproducibility kit (github.com/denisa-c/gridpilot)
# =====================================================================

# -- Python ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
*.egg-info/
*.eggs/
build/
dist/
pip-log.txt
pip-delete-this-directory.txt

# -- Test / lint caches --------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# -- Jupyter --------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_meta.json

# -- OS / Editor ----------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# -- Local secrets / API tokens ------------------------------------
.entsoe_api_key
secrets.yaml
.env.local
.env.*.local

# -- Large generated data (regenerated by run_all_experiments.sh) ---
# Source-of-truth raw data is fetched/created by the run scripts; the
# CSV/Parquet outputs below are reproducible.
data/raw/
data/entsoe_cache/
data/m100/policy_matrix/policy_matrix.csv
data/m100/policy_matrix/HYPOTHESIS_OUTCOMES.json
data/m100/policy_matrix/RUN_MANIFEST.json
data/m100/country_sweep/country_sweep.csv
data/m100/country_sweep/COUNTRY_SUMMARY.csv
data/m100/country_sweep/RUN_MANIFEST.json
data/m100/country_sweep/cells/
data/m100/ci_series/
data/traces/m100_real_jobs_extended.parquet
*.csv.gz
*.parquet.tmp

# Keep small bundled traces under data/traces/ AND keep stub seeds
# (they live alongside the .py scripts that generate them).
!data/traces/m100_real_jobs.parquet
!data/m100/.gitkeep
!data/m100/policy_matrix/.gitkeep
!data/m100/country_sweep/.gitkeep
# Keep reproducibility headline outputs versioned.
!data/m100/policy_matrix/policy_matrix.csv
!data/m100/policy_matrix/HYPOTHESIS_OUTCOMES.json
!data/m100/policy_matrix/RUN_MANIFEST.json
!data/m100/country_sweep/country_sweep.csv
!data/m100/country_sweep/COUNTRY_SUMMARY.csv
!data/m100/country_sweep/RUN_MANIFEST.json

# -- Raw V100 telemetry --------------------------------------------
# Keep the small headline summary CSVs (referenced by extract_paper_macros);
# ignore the large per-trial CSVs (regenerated by the experiment scripts).
data/v100_raw/E1_power_cap_sweep/*.csv
data/v100_raw/E2_inner_loop/*.csv
data/v100_raw/E3_outer_loop/*.csv
data/v100_raw/E4_closed_loop/*.csv
data/v100_raw/E7_ffr_latency/*.csv
data/v100_raw/E7_ffr_latency/per_trial/
!data/v100_raw/headline_table.csv
!data/v100_raw/E7_ffr_latency/verdict.json
!data/v100_raw/cross_validation/comparison_report.md
!data/v100_raw/cross_validation/comparison_report.json

# -- Figures (regenerated from scripts/figures/) -------------------
figs/*.pdf
figs/*.png
figures/*.pdf
figures/*.png
!figs/.gitkeep
!figures/.gitkeep
# Keep the editable masters that ship with the repo.
!figs/*.tex
!figs/*.svg
!figures/*.tex
!figures/*.svg
# Keep paper-facing generated PDFs from run_all_experiments.sh.
!figs/fig_cfe_by_tier.pdf
!figs/fig_swf_comparison.pdf
!figs/fig_fairness_pareto.pdf
!figs/fig_latency_per_tier.pdf
!figs/fig_country_cfe_lift.pdf
!figs/fig_country_pue_aware.pdf

# -- LaTeX build artefacts -----------------------------------------
# Papers live under ../papers/ at the project root, but if anyone
# clones the kit into a setup where papers are siblings, mask their
# auxiliary files here too.
**/*.aux
**/*.bbl
**/*.blg
**/*.fdb_latexmk
**/*.fls
**/*.log
**/*.out
**/*.synctex.gz
**/*.toc
**/_minted-*/
**/auto/
papers/build/

# -- Reinforcement-learning / RAPS submodule outputs ---------------
raps/simulation_results/
raps/raps-output-*
raps/ppo_raps_logs/
raps/models/fmu-models/
raps/models/POWER9CSM/
raps/.shell-completion-cache

# -- Shell completion / misc ---------------------------------------
*.prof
*.npz
*.bak
*.orig
